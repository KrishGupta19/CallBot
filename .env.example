# Groq API (free tier) — https://console.groq.com
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_STT_MODEL=whisper-large-v3-turbo
USER_SPEECH_STOP_SECS=0.6
USER_TURN_TIMEOUT_SECS=0.35

# TTS provider: "elevenlabs" or "cartesia"
TTS_PROVIDER=elevenlabs

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# Cartesia API (free trial) — https://play.cartesia.ai
CARTESIA_API_KEY=
# Twilio credentials — https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=
# ngrok URL (update this every time ngrok restarts on free tier)
NGROK_URL=
